{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Next.js App Router (Chrome)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}",
      "sourceMaps": true,
      "trace": true,
      "skipFiles": [
        "<node_internals>/**",
        "**/node_modules/**/*.js",
        "**/node_modules/**/*.mjs"
      ],
      "sourceMapPathOverrides": {
        "webpack:///./*": "${webRoot}/*",
        "webpack:///app/*": "${webRoot}/app/*",
        "webpack:///src/*": "${webRoot}/src/*",
        "webpack:///pages/*": "${webRoot}/pages/*",
        "webpack://_N_E/./*": "${webRoot}/*"
      }
    }
  ]
}
